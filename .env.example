# Streamlit server configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Dataset configuration
DATASET_NAME=NASA_SMAP
DATASET_CHANNEL=P-1
DATASET_RAW_DIR=data/raw
DATASET_PROCESSED_DIR=data/processed

# Model hyperparameters
WINDOW_SIZE=100
LATENT_DIM=32
TCN_LAYERS=4
TCN_KERNEL_SIZE=3
TCN_CHANNELS=64
BATCH_SIZE=64
EPOCHS=50
LEARNING_RATE=0.001

# Thresholding parameters
PERCENTILE_QUANTILE=0.99
POT_INITIAL_QUANTILE=0.95

# Paths
MODEL_DIR=models
RESULTS_DIR=results
